      {
        "parameters": {
          "jsCode": "const targetMatch = $input.first().json.output.contentSnippet;\nconst searchItems = $('Start').all();\nconst regX = /(?<=[.!?])\\s/;\n\nreturn searchItems.filter(item => {\n  const text = item.json.contentSnippet || \"\";\n  // Extract first sentence: split by punctuation followed by space\n  const firstSentence = text.split(regX)[0].trim();\n  return targetMatch.includes(firstSentence);\n});"
        },
        "type": "n8n-nodes-base.code",
