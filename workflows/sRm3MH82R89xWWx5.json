        "jsonBody": "={\n  \"author\": \"urn:li:person:{{ $json.sub }}\",\n  \"lifecycleState\": \"PUBLISHED\",\n  \"specificContent\": {\n    \"com.linkedin.ugc.ShareContent\": {\n      \"shareCommentary\": {\n        \"text\": \"{{ $('Content Builder Agent').item.json.output.content }}\\n\\n{{ $('Content Builder Agent').item.json.output.hashtags }}\"\n      },\n      \"shareMediaCategory\": \"ARTICLE\",\n      \"media\": [\n        {\n          \"status\": \"READY\",\n          \"description\": {\n            \"text\": \"{{ $('Selection Agent').item.json.output.contentSnippet }}\"\n          },\n          \"originalUrl\": \"{{ $('Selection Agent').item.json.output.url }}\",\n          \"title\": {\n            \"text\": \"{{ $('Selection Agent').item.json.output.title }}\"\n          },\n          \"thumbnails\":[\n            {\n              \"url\":\"{{ $('Selection Agent').item.json.output.img }}\"\n            }\n          ]\n        }\n      ]\n    }\n  },\n  \"visibility\": {\n    \"com.linkedin.ugc.MemberNetworkVisibility\": \"PUBLIC\"\n  }\n}",
        "options": {}
